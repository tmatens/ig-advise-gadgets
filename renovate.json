{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Keep the repo-root IG_VERSION pin in lockstep with the inspektor-gadget Go module",
      "managerFilePatterns": [
        "/^IG_VERSION$/"
      ],
      "matchStrings": [
        "^(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)\\s*$"
      ],
      "depNameTemplate": "github.com/inspektor-gadget/inspektor-gadget",
      "datasourceTemplate": "go"
    }
  ],
  "packageRules": [
    {
      "description": "Bump the IG go module and the IG_VERSION pin together in a single PR",
      "matchDepNames": [
        "github.com/inspektor-gadget/inspektor-gadget"
      ],
      "groupName": "inspektor-gadget"
    }
  ]
}
